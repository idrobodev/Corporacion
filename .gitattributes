# Default behavior: automatically normalize line endings
* text=auto

# Force LF for source files
*.sh text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.sql text eol=lf
*.java text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.env.example text eol=lf

# Windows batch files keep CRLF
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg binary
*.avif binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.pdf binary